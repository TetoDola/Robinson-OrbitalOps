DATABASE_URL=postgresql+asyncpg://robinson:robinson@localhost:5432/robinson
REDIS_URL=redis://localhost:6379/0

CRUSOE_API_KEY=
CRUSOE_BASE_URL=https://api.inference.crusoecloud.com/v1/
CRUSOE_MODEL=nvidia/Nemotron-3-Nano-Omni-Reasoning-30B-A3B
CRUSOE_MULTIMODAL_MODEL=nvidia/Nemotron-3-Nano-Omni-Reasoning-30B-A3B
CRUSOE_ENABLED=true
CRUSOE_AGENT_ANALYSIS_ENABLED=true

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/auto
OPENROUTER_MULTIMODAL_MODEL=openrouter/auto
OPENROUTER_ENABLED=true
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=Robinson OrbitOps

APP_NAME=Robinson API
API_HOST=0.0.0.0
API_PORT=8000
WORLD_STATE_SEED_VERSION=1
WEBSOCKET_HEARTBEAT_SECONDS=5.0

LOCAL_GPU_TELEMETRY_ENABLED=false
LOCAL_GPU_NODE_ID=node-local
LOCAL_GPU_ASSET_ID=gpu-local-0

ROBINSON_RADIATION_SOURCE=auto
ROBINSON_RADIATION_CACHE_SECONDS=60
ROBINSON_RADIATION_TIMEOUT_SECONDS=2.5
