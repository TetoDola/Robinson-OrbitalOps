DATABASE_URL=postgresql+asyncpg://orbitops:orbitops@localhost:5432/orbitops
REDIS_URL=redis://localhost:6379/0

CRUSOE_API_KEY=
CRUSOE_BASE_URL=https://api.inference.crusoecloud.com/v1/
CRUSOE_MODEL=moonshotai/Kimi-K2.6
CRUSOE_MULTIMODAL_MODEL=nvidia/Nemotron-3-Nano-Omni-Reasoning-30B-A3B
CRUSOE_ENABLED=false

APP_NAME=OrbitOps API
API_HOST=0.0.0.0
API_PORT=8000
WORLD_STATE_SEED_VERSION=1
WEBSOCKET_HEARTBEAT_SECONDS=5.0

LOCAL_GPU_TELEMETRY_ENABLED=false
LOCAL_GPU_NODE_ID=node-local
LOCAL_GPU_ASSET_ID=gpu-local-0
